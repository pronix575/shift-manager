# API
PORT=4000
API_PREFIX=api
APP_ORIGIN=http://localhost:3005
CORS_ORIGINS=*
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require

# Auth
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Seed
INITIAL_ADMIN_LOGIN=admin
INITIAL_ADMIN_PASSWORD=change-me-now

# Shifts
SHIFT_EMPLOYEE_EDIT_LIMIT_MINUTES=1440
XLSX_EXPORT_MAX_ROWS=10000

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_MODE=disabled
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=replace-me-webhook-secret
TELEGRAM_LINK_CODE_TTL_MINUTES=15

# Web
VITE_API_URL=/api
